              "script": {
                "exec": [
                  "pm.test('Allow permission request returns success status', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200]);",
                  "});",
                  "",
                  "pm.test('Allow permission response time is acceptable', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('Allow permission response has a recognizable content type when a body is returned', function () {",
                  "    if (pm.response.code !== 204 && pm.response.text().length > 0) {",
                  "        pm.expect(pm.response.headers.get('Content-Type')).to.match(/application\\/(json|problem\\+json|text\\+json)|text\\//i);",
